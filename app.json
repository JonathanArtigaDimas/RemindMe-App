{
  "expo": {
    "name": "RemindMe",
    "slug": "RemindMe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "remindme",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/adaptive-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F23"
    },
    "android": {
      "package": "com.remindme.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#6C63FF"
      },
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {}
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Permitir a RemindMe acceder al micrófono para grabar sonidos personalizados para tus recordatorios."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir a RemindMe acceder a tus fotos para adjuntarlas en notas.",
          "cameraPermission": "Permitir a RemindMe usar la cámara para capturar fotos en tus notas."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "kotlinVersion": "1.9.25",
            "extraGRADLE_OPTS": "-Xmx2048m"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7cdecdc1-2b48-4f31-a94d-ebfe6c1d9560"
      }
    },
    "owner": "artiga"
  }
}